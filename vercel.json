{
  "version": 2,
  "functions": {
    "aqi_prediction.py": {
      "runtime": "python3.9"
    }
  },
  "builds": [
    {
      "src": "aqi_prediction.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/aqi_prediction.py"
    }
  ]
}